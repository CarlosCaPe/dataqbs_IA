---
export const prerender = true;

import RealestateLayout from '../../layouts/RealestateLayout.astro';
import RealestateHeader from '../../components/realestate/RealestateHeader.svelte';
import PropertyPage from '../../components/realestate/PropertyPage.svelte';

// Import the property data
import propertyData from '../../../../malaga/ventaDepartamento/ficha_tecnica.json';
---

<RealestateLayout
  title={`${propertyData.title_short} | realestate`}
  description={propertyData.description_short}
  image="/realestate/ventaDepartamento/FACHADA_01.jpeg"
>
  <!-- JSON-LD Structured Data for this property -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'RealEstateListing',
    name: propertyData.title,
    description: propertyData.description_short,
    url: 'https://www.dataqbs.com/realestate/ventaDepartamento/',
    image: 'https://www.dataqbs.com/realestate/ventaDepartamento/FACHADA_01.jpeg',
    datePosted: '2025-12-01',
    offers: {
      '@type': 'Offer',
      price: propertyData.operations?.[0]?.amount,
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
    },
    address: {
      '@type': 'PostalAddress',
      streetAddress: propertyData.location?.name,
      addressLocality: propertyData.location?.city,
      addressRegion: propertyData.location?.state,
      postalCode: propertyData.location?.zip,
      addressCountry: 'MX',
    },
  })} slot="head" />
  <RealestateHeader client:load />

  <!-- Decorative RE watermarks -->
  <div class="hidden lg:block fixed left-0 top-16 bottom-0 w-12 pointer-events-none z-10" aria-hidden="true">
    <div class="flex flex-col items-center gap-16 pt-8 opacity-[0.04]">
      <img src="/re-favicon.svg" alt="" class="w-10 h-10" />
      <img src="/re-favicon.svg" alt="" class="w-10 h-10" />
      <img src="/re-favicon.svg" alt="" class="w-10 h-10" />
    </div>
  </div>
  <div class="hidden lg:block fixed right-0 top-16 bottom-0 w-12 pointer-events-none z-10" aria-hidden="true">
    <div class="flex flex-col items-center gap-16 pt-8 opacity-[0.04]">
      <img src="/re-favicon.svg" alt="" class="w-10 h-10" />
      <img src="/re-favicon.svg" alt="" class="w-10 h-10" />
      <img src="/re-favicon.svg" alt="" class="w-10 h-10" />
    </div>
  </div>

  <main>
    <PropertyPage
      client:load
      property={propertyData}
      basePath="/realestate/ventaDepartamento"
    />
  </main>
</RealestateLayout>
