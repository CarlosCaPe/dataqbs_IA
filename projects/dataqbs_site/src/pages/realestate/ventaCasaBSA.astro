---
export const prerender = true;

import RealestateLayout from '../../layouts/RealestateLayout.astro';
import RealestateHeader from '../../components/realestate/RealestateHeader.svelte';
import PropertyPage from '../../components/realestate/PropertyPage.svelte';

// Import the property data
import propertyData from '../../../../malaga/ventaCasaBSA/ficha_tecnica.json';
---

<RealestateLayout
  title={`${propertyData.title_short} | realestate`}
  description={propertyData.description_short}
  image="/realestate/ventaCasaBSA/FACHADA_01v2.jpeg"
>
  <!-- JSON-LD Structured Data for this property -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'RealEstateListing',
    name: propertyData.title,
    description: propertyData.description_short,
    url: 'https://www.dataqbs.com/realestate/ventaCasaBSA/',
    image: 'https://www.dataqbs.com/realestate/ventaCasaBSA/FACHADA_01v2.jpeg',
    datePosted: '2025-12-01',
    offers: {
      '@type': 'Offer',
      price: propertyData.operations?.[0]?.amount,
      priceCurrency: 'MXN',
      availability: 'https://schema.org/InStock',
    },
    address: {
      '@type': 'PostalAddress',
      streetAddress: propertyData.location?.name,
      addressLocality: propertyData.location?.city,
      addressRegion: propertyData.location?.state,
      postalCode: propertyData.location?.zip,
      addressCountry: 'MX',
    },
  })} slot="head" />
  <RealestateHeader client:load />

  <!-- Decorative RE watermarks (subtle, sidebar) -->
  <div class="hidden lg:block fixed left-1 top-20 bottom-0 w-8 pointer-events-none z-10 overflow-hidden" aria-hidden="true">
    <div class="flex flex-col items-center gap-20 pt-8 opacity-[0.03]">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="24" height="24" fill="none"><rect width="64" height="64" rx="14" fill="#dc2626"/><text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-weight="700" font-size="28" fill="white">RE</text></svg>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="24" height="24" fill="none"><rect width="64" height="64" rx="14" fill="#dc2626"/><text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-weight="700" font-size="28" fill="white">RE</text></svg>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="24" height="24" fill="none"><rect width="64" height="64" rx="14" fill="#dc2626"/><text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-weight="700" font-size="28" fill="white">RE</text></svg>
    </div>
  </div>
  <div class="hidden lg:block fixed right-1 top-20 bottom-0 w-8 pointer-events-none z-10 overflow-hidden" aria-hidden="true">
    <div class="flex flex-col items-center gap-20 pt-8 opacity-[0.03]">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="24" height="24" fill="none"><rect width="64" height="64" rx="14" fill="#dc2626"/><text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-weight="700" font-size="28" fill="white">RE</text></svg>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="24" height="24" fill="none"><rect width="64" height="64" rx="14" fill="#dc2626"/><text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-weight="700" font-size="28" fill="white">RE</text></svg>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="24" height="24" fill="none"><rect width="64" height="64" rx="14" fill="#dc2626"/><text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-weight="700" font-size="28" fill="white">RE</text></svg>
    </div>
  </div>

  <main>
    <PropertyPage
      client:load
      property={propertyData}
      basePath="/realestate/ventaCasaBSA"
    />
  </main>
</RealestateLayout>
