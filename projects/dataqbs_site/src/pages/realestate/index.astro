---
export const prerender = true;

import RealestateLayout from '../../layouts/RealestateLayout.astro';
import RealestateHeader from '../../components/realestate/RealestateHeader.svelte';
import PropertyContact from '../../components/realestate/PropertyContact.svelte';

// Import both property data files
import casaData from '../../../../malaga/ventaCasaBSA/ficha_tecnica.json';
import deptoData from '../../../../malaga/ventaDepartamento/ficha_tecnica.json';

const properties = [
  { data: casaData, slug: 'ventaCasaBSA', image: '/realestate/ventaCasaBSA/FACHADA_01.jpeg' },
  { data: deptoData, slug: 'ventaDepartamento', image: '/realestate/ventaDepartamento/FACHADA_EDIFICIO_01.jpeg' },
];
---

<RealestateLayout
  title="realestate | Propiedades en Venta"
  description="Casas y departamentos en venta en Guadalajara y zona metropolitana. Propiedades verificadas con ficha técnica completa."
>
  <RealestateHeader client:load />

  <!-- Decorative RS watermarks -->
  <div class="hidden lg:block fixed left-0 top-16 bottom-0 w-12 pointer-events-none z-10" aria-hidden="true">
    <div class="flex flex-col items-center gap-16 pt-8 opacity-[0.04]">
      <img src="/re-favicon.svg" alt="" class="w-10 h-10" />
      <img src="/re-favicon.svg" alt="" class="w-10 h-10" />
      <img src="/re-favicon.svg" alt="" class="w-10 h-10" />
    </div>
  </div>
  <div class="hidden lg:block fixed right-0 top-16 bottom-0 w-12 pointer-events-none z-10" aria-hidden="true">
    <div class="flex flex-col items-center gap-16 pt-8 opacity-[0.04]">
      <img src="/re-favicon.svg" alt="" class="w-10 h-10" />
      <img src="/re-favicon.svg" alt="" class="w-10 h-10" />
      <img src="/re-favicon.svg" alt="" class="w-10 h-10" />
    </div>
  </div>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
    <!-- Mini header -->
    <div class="flex items-center justify-center gap-2 mb-8">
      <img src="/re-favicon.svg" alt="realestate" class="w-8 h-8" />
      <span class="text-2xl font-bold text-re-600 dark:text-re-400">realestate</span>
    </div>

    <!-- Property photos grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      {properties.map((prop) => (
        <a
          href={`/realestate/${prop.slug}`}
          class="group relative block rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 aspect-[4/3]"
        >
          <img
            src={prop.image}
            alt={prop.data.title_short}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <!-- Gradient overlay with title -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-300" />
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <h2 class="text-white font-bold text-lg sm:text-xl drop-shadow-lg">
              {prop.data.title_short}
            </h2>
            <span class="inline-block mt-2 px-3 py-1 rounded-full text-xs font-semibold bg-re-600 text-white shadow">
              {prop.data.operations?.[0]?.formatted_amount || 'Consultar'}
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- Contact Section -->
    <div class="mt-10 card p-6">
      <PropertyContact
        client:load
        propertyTitle="realestate — Propiedades en Venta"
        propertyId="landing"
      />
    </div>

    <!-- Footer -->
    <footer class="mt-10 pt-6 pb-4 text-center">
      <p class="text-xs text-slate-400 dark:text-slate-500">
        © {new Date().getFullYear()} realestate
      </p>
    </footer>
  </main>
</RealestateLayout>
