---
export const prerender = true;

import RealestateLayout from '../../layouts/RealestateLayout.astro';
import RealestateHeader from '../../components/realestate/RealestateHeader.svelte';
import PropertyContact from '../../components/realestate/PropertyContact.svelte';
import PropertyCard from '../../components/realestate/PropertyCard.svelte';

// Import both property data files
import casaData from '../../../../malaga/ventaCasaBSA/ficha_tecnica.json';
import deptoData from '../../../../malaga/ventaDepartamento/ficha_tecnica.json';

const properties = [
  { data: casaData, slug: 'ventaCasaBSA', image: '/realestate/ventaCasaBSA/FACHADA_01.jpeg' },
  { data: deptoData, slug: 'ventaDepartamento', image: '/realestate/ventaDepartamento/FACHADA_EDIFICIO_01.jpeg' },
];
---

<RealestateLayout
  title="realestate | Propiedades en Venta"
  description="Casas y departamentos en venta en Guadalajara y zona metropolitana. Propiedades verificadas con ficha técnica completa."
>
  <RealestateHeader client:load />

  <!-- Decorative RE watermarks (subtle, sidebar) -->
  <div class="hidden lg:block fixed left-1 top-20 bottom-0 w-8 pointer-events-none z-10 overflow-hidden" aria-hidden="true">
    <div class="flex flex-col items-center gap-20 pt-8 opacity-[0.03]">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="24" height="24" fill="none"><rect width="64" height="64" rx="14" fill="#dc2626"/><text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-weight="700" font-size="28" fill="white">RE</text></svg>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="24" height="24" fill="none"><rect width="64" height="64" rx="14" fill="#dc2626"/><text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-weight="700" font-size="28" fill="white">RE</text></svg>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="24" height="24" fill="none"><rect width="64" height="64" rx="14" fill="#dc2626"/><text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-weight="700" font-size="28" fill="white">RE</text></svg>
    </div>
  </div>
  <div class="hidden lg:block fixed right-1 top-20 bottom-0 w-8 pointer-events-none z-10 overflow-hidden" aria-hidden="true">
    <div class="flex flex-col items-center gap-20 pt-8 opacity-[0.03]">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="24" height="24" fill="none"><rect width="64" height="64" rx="14" fill="#dc2626"/><text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-weight="700" font-size="28" fill="white">RE</text></svg>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="24" height="24" fill="none"><rect width="64" height="64" rx="14" fill="#dc2626"/><text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-weight="700" font-size="28" fill="white">RE</text></svg>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="24" height="24" fill="none"><rect width="64" height="64" rx="14" fill="#dc2626"/><text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-weight="700" font-size="28" fill="white">RE</text></svg>
    </div>
  </div>

  <main class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
    <!-- Mini header -->
    <div class="flex items-center justify-center gap-2 mb-8">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="32" height="32" fill="none" class="w-8 h-8 flex-shrink-0"><rect width="64" height="64" rx="14" fill="#dc2626"/><text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-weight="700" font-size="28" fill="white">RE</text></svg>
      <span class="text-2xl font-bold text-re-600 dark:text-re-400">realestate</span>
    </div>

    <!-- Property photos grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      {properties.map((prop) => (
        <PropertyCard
          client:load
          slug={prop.slug}
          image={prop.image}
          title_short={prop.data.title_short}
          title_short_i18n={prop.data.title_short_i18n}
          formatted_amount={prop.data.operations?.[0]?.formatted_amount || 'Consultar'}
        />
      ))}
    </div>

    <!-- Contact Section -->
    <div class="mt-10 card p-6">
      <PropertyContact
        client:load
        propertyTitle="realestate — Propiedades en Venta"
        propertyId="landing"
      />
    </div>

    <!-- Footer -->
    <footer class="mt-10 pt-6 pb-4 text-center">
      <p class="text-xs text-slate-400 dark:text-slate-500">
        © {new Date().getFullYear()} realestate
      </p>
    </footer>
  </main>
</RealestateLayout>
